{
	"name": "obsidian-mirror-notes",
	"version": "1.1.0",
	"description": "Display dynamic templates in your notes based on frontmatter properties",
	"type": "module",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "wdio run wdio.conf.mts",
		"test:visual:update": "wdio run wdio.conf.mts -- --update-visual-baseline",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [],
	"author": "mrlnlms",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/state": "^6.5.4",
		"@codemirror/view": "^6.39.17",
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.19.15",
		"@typescript-eslint/eslint-plugin": "^8.57.0",
		"@typescript-eslint/parser": "^8.57.0",
		"@wdio/cli": "^9.0.0",
		"@wdio/globals": "^9.0.0",
		"@wdio/local-runner": "^9.0.0",
		"@wdio/mocha-framework": "^9.0.0",
		"@wdio/spec-reporter": "^9.0.0",
		"@wdio/visual-service": "^9.2.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.25.12",
		"eslint": "^9.39.4",
		"jsdom": "^28.1.0",
		"obsidian": "^1.12.3",
		"obsidian-e2e-visual-test-kit": "github:mrlnlms/obsidian-e2e-visual-test-kit",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vitest": "^4.0.18",
		"wdio-obsidian-reporter": "^2.4.0",
		"wdio-obsidian-service": "^2.4.0",
		"webdriverio": "^9.18.0"
	},
	"dependencies": {
		"@popperjs/core": "^2.11.8"
	}
}
